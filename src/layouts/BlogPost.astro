---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Prose from '../components/Prose.astro';
import { slugify, withBase } from '../utils/slugify';
import readingTime from 'reading-time';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ImageMetadata;
  Content?: any;
  tags?: string[];
}

const post = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags = [], Content } = post as Props;

const body = post.entry?.body || '';
const stats = readingTime(body);
---

<BaseLayout title={title} description={description} image={heroImage}>

<div id="progress"></div>

<div class="content-shell">
<article class="post max-w-3xl mx-auto">

<a href="/blog" class="text-sm text-muted">← Back to writing</a>

<header class="mt-6">
<h1>{title}</h1>

<p class="post-meta">
<FormattedDate date={pubDate} /> · {stats.text}
{updatedDate && (<span> · Updated <FormattedDate date={updatedDate} /></span>)}
</p>

<hr />

{tags.length > 0 && (
<ul class="mt-3 flex flex-wrap gap-2 text-sm text-muted">
{tags.map(tag => (
<li class="rounded-full border border-border px-3 py-1">
<a href={withBase(`/tags/${slugify(tag)}/`)}>{tag}</a>
</li>
))}
</ul>
)}

</header>

{heroImage && (
<figure class="my-8">
<Image width={1020} height={510} src={heroImage} alt="" />
</figure>
)}

<section class="post-article">
<Prose>
{Content ? <Content /> : <slot />}
</Prose>
</section>

</article>
</div>

</BaseLayout>

<script>
const bar = document.getElementById("progress");

window.addEventListener("scroll", () => {
  const h = document.documentElement;
  bar.style.width =
    (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100 + "%";
});

// fade-in paragraphs
const paras = document.querySelectorAll(".post-article p");

const obs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) e.target.classList.add("visible");
  });
});

paras.forEach(p => {
  p.classList.add("fade");
  obs.observe(p);
});
</script>

<style>
#progress {
  position: fixed;
  top: 0;
  left: 0;
  height: 3px;
  background: var(--color-ink);
  width: 0%;
  z-index: 90;
}

.post {
  line-height: 1.75;
  font-size: 1.05rem;
}

.post h1,
.post h2,
.post h3 {
  margin-top: 2.2em;
}

.post p {
  margin: 1.2em 0;
}

/* Drop cap */
.post-article p:first-of-type::first-letter {
  float: left;
  font-size: 3rem;
  line-height: 1;
  padding-right: .3rem;
  font-weight: 600;
}

/* Fade animation */
.fade {
  opacity: 0;
  transform: translateY(8px);
  transition: .6s ease;
}

.fade.visible {
  opacity: 1;
  transform: none;
}
</style>
