---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Prose from '../components/Prose.astro';
import { slugify, withBase } from '../utils/slugify';
import readingTime from 'reading-time';
import { getCollection } from 'astro:content';
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ImageMetadata;
  Content?: any;
  tags?: string[];
}
const post = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags = [], Content } = post as Props;
const body = post.entry?.body || '';
const stats = readingTime(body);

const allPosts = await getCollection('blog');
const sorted = allPosts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
const currentIndex = sorted.findIndex(p => p.data.title === title);
const prev = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const next = currentIndex > 0 ? sorted[currentIndex - 1] : null;
---
<BaseLayout title={title} description={description} image={heroImage}>
<div id="progress"></div>
<div class="content-shell">
  <article class="post max-w-3xl mx-auto">

    <a href="/blog" class="text-sm text-muted no-underline hover:underline">← Back to writing</a>

    <header class="mt-4 space-y-2">
      <h1 class="m-0">{title}</h1>
      <p class="post-meta text-sm text-muted m-0">
        <FormattedDate date={pubDate} /> · {stats.text}
        {updatedDate && (<span> · Updated <FormattedDate date={updatedDate} /></span>)}
      </p>
      <hr />
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            <a href={withBase(`/tags/${slugify(tag)}/`)} class="post-tag">
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    {heroImage && (
      <figure class="my-8">
        <Image width={1020} height={510} src={heroImage} alt="" />
      </figure>
    )}

    <section class="post-article mt-8 drop-cap-section">
      <Prose>
        {Content ? <Content /> : <slot />}
      </Prose>
    </section>

    <nav class="post-nav">
      <div>
        {prev && (
          <a href={withBase(`/blog/${prev.id}/`)} class="post-nav-link">
            <span class="eyebrow">Previous</span>
            <span class="post-nav-title">{prev.data.title}</span>
          </a>
        )}
      </div>
      <div class="text-right">
        {next && (
          <a href={withBase(`/blog/${next.id}/`)} class="post-nav-link">
            <span class="eyebrow">Next</span>
            <span class="post-nav-title">{next.data.title}</span>
          </a>
        )}
      </div>
    </nav>

  </article>
</div>
</BaseLayout>

<script>
const bar = document.getElementById("progress");
window.addEventListener("scroll", () => {
  const h = document.documentElement;
  bar.style.width =
    (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100 + "%";
});
const paras = document.querySelectorAll(".post-article p");
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) e.target.classList.add("visible");
  });
});
paras.forEach(p => {
  p.classList.add("fade");
  obs.observe(p);
});
</script>

<style>
#progress {
  position: fixed;
  top: 0;
  left: 0;
  height: 2px;
  background: var(--color-ink);
  width: 0%;
  z-index: 90;
  opacity: 0.6;
}
.post {
  line-height: 1.8;
  font-size: 1.05rem;
}
.post h1,
.post h2,
.post h3 {
  margin-top: 2.2em;
}
.post p {
  margin: 1.2em 0;
}
.post-article p:first-of-type::first-letter {
  float: left;
  font-size: 3rem;
  line-height: 1;
  padding-right: 0.3rem;
  font-weight: 700;
  font-family: var(--font-serif);
}
.post-tag {
  font-size: 0.65rem;
  font-family: var(--font-mono, monospace);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-muted);
  border: 1px solid var(--color-border);
  padding: 0.15rem 0.5rem;
  text-decoration: none;
  transition: color 140ms ease, border-color 140ms ease;
}
.post-tag:hover {
  color: var(--color-ink);
  border-color: var(--color-ink);
}
.post-nav {
  margin-top: 4rem;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}
.post-nav-link {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  text-decoration: none;
}
.post-nav-title {
  font-family: var(--font-serif);
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--color-ink);
  transition: color 140ms ease;
}
.post-nav-link:hover .post-nav-title {
  color: var(--color-accent);
}
.fade {
  opacity: 0;
  transform: translateY(6px);
  transition: 0.5s ease;
}
.fade.visible {
  opacity: 1;
  transform: none;
}
</style>
