---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Prose from '../components/Prose.astro';
import { slugify, withBase } from '../utils/slugify';
import readingTime from 'reading-time';
import { getCollection } from 'astro:content';
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ImageMetadata;
  Content?: any;
  tags?: string[];
}
const post = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags = [], Content } = post as Props;
const body = post.entry?.body || '';
const stats = readingTime(body);

const allPosts = await getCollection('blog');
const sorted = allPosts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
const currentIndex = sorted.findIndex(p => p.data.title === title);
const prev = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const next = currentIndex > 0 ? sorted[currentIndex - 1] : null;
---
<BaseLayout title={title} description={description} image={heroImage}>
<div id="progress"></div>
<div class="content-shell">
  <article class="post max-w-3xl mx-auto">

    <a href="/blog" class="text-sm text-muted no-underline hover:underline">← Back to writing</a>

    <header class="mt-6 space-y-3">
      <h1 class="m-0">{title}</h1>
      <p class="post-meta text-sm text-muted m-0">
        <FormattedDate date={pubDate} /> · {stats.text}
        {updatedDate && (<span> · Updated <FormattedDate date={updatedDate} /></span>)}
      </p>
      <hr />
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            
              href={withBase(`/tags/${slugify(tag)}/`)}
              class="text-xs font-mono uppercase tracking-widest text-muted border border-[color:var(--color-border)] px-2 py-0.5 no-underline hover:text-[color:var(--color-ink)] hover:border-[color:var(--color-ink)] transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    {heroImage && (
      <figure class="my-8">
        <Image width={1020} height={510} src={heroImage} alt="" />
      </figure>
    )}

    <section class="post-article mt-8">
      <Prose>
        {Content ? <Content /> : <slot />}
      </Prose>
    </section>

    <nav class="mt-16 pt-8 border-t border-[color:var(--color-border)] grid grid-cols-2 gap-4 text-sm">
      <div>
        {prev && (
          <a href={withBase(`/blog/${prev.id}/`)} class="group no-underline space-y-1">
            <p class="eyebrow m-0">Previous</p>
            <p class="m-0 font-medium group-hover:text-[color:var(--color-accent)] transition-colors">
              {prev.data.title}
            </p>
          </a>
        )}
      </div>
      <div class="text-right">
        {next && (
          <a href={withBase(`/blog/${next.id}/`)} class="group no-underline space-y-1">
            <p class="eyebrow m-0">Next</p>
            <p class="m-0 font-medium group-hover:text-[color:var(--color-accent)] transition-colors">
              {next.data.title}
            </p>
          </a>
        )}
      </div>
    </nav>

  </article>
</div>
</BaseLayout>

<script>
const bar = document.getElementById("progress");
window.addEventListener("scroll", () => {
  const h = document.documentElement;
  bar.style.width =
    (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100 + "%";
});
const paras = document.querySelectorAll(".post-article p");
const obs = new Inters
