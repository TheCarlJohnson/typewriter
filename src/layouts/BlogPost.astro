---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Prose from '../components/Prose.astro';
import { slugify, withBase } from '../utils/slugify';
import readingTime from 'reading-time';
import { getCollection } from 'astro:content';
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ImageMetadata;
  Content?: any;
  tags?: string[];
}
const post = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags = [], Content } = post as Props;
const body = post.entry?.body || '';
const stats = readingTime(body);
const allPosts = await getCollection('blog');
const sorted = allPosts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
const currentIndex = sorted.findIndex(p => p.data.title === title);
const prev = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const next = currentIndex > 0 ? sorted[currentIndex - 1] : null;

const related = sorted
  .filter(p => p.data.title !== title)
  .filter(p => p.data.tags?.some(t => tags.includes(t)))
  .slice(0, 2);
---
<BaseLayout title={title} description={description} image={heroImage}>
  <div id="progress"></div>
  <div class="content-shell">
    <article class="post max-w-3xl mx-auto">

      <a href="/blog" class="back-link">← Back to writing</a>

      <header class="post-header">
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 justify-center mb-4">
            {tags.map(tag => (
              <a href={withBase(`/tags/${slugify(tag)}/`)} class="post-tag">{tag}</a>
            ))}
          </div>
        )}
        <h1 class="post-title">{title}</h1>
        <div class="post-byline">
          <FormattedDate date={pubDate} />
          <span class="byline-sep">·</span>
          <span>{stats.text}</span>
          {updatedDate && (
            <>
              <span class="byline-sep">·</span>
              <span>Updated <FormattedDate date={updatedDate} /></span>
            </>
          )}
        </div>
        <div class="post-rule"></div>
      </header>

      {heroImage && (
        <figure class="post-hero-figure">
          <Image width={1020} height={510} src={heroImage} alt={title} />
        </figure>
      )}

      <section class="post-article drop-cap-section">
        <Prose>
          {Content ? <Content /> : <slot />}
        </Prose>
      </section>

      {related.length > 0 && (
        <aside class="related-posts">
          <p class="eyebrow" style="margin-bottom:1rem;">Related writing</p>
          <div class="related-list">
            {related.map(p => (
              <a href={withBase(`/blog/${p.id}/`)} class="related-item">
                <span class="related-title">{p.data.title}</span>
                <span class="related-meta">{readingTime(p.body ?? '').text}</span>
              </a>
            ))}
          </div>
        </aside>
      )}

      <nav class="post-nav">
        <div>
          {prev && (
            <a href={withBase(`/blog/${prev.id}/`)} class="post-nav-link">
              <span class="eyebrow">Previous</span>
              <span class="post-nav-title">{prev.data.title}</span>
            </a>
          )}
        </div>
        <div class="text-right">
          {next && (
            <a href={withBase(`/blog/${next.id}/`)} class="post-nav-link">
              <span class="eyebrow">Next</span>
              <span class="post-nav-title">{next.data.title}</span>
            </a>
          )}
        </div>
      </nav>

    </article>
  </div>

  <button class="back-to-top" id="back-to-top" aria-label="Back to top">↑</button>
</BaseLayout>

<script>
const bar = document.getElementById("progress") as HTMLElement;
const btn = document.getElementById("back-to-top") as HTMLElement;

window.addEventListener("scroll", () => {
  const h = document.documentElement;
  const pct = h.scrollTop / (h.scrollHeight - h.clientHeight);
  bar.style.width = pct * 100 + "%";
  if (h.scrollTop > 400) {
    btn.classList.add("visible");
  } else {
    btn.classList.remove("visible");
  }
});

btn.addEventListener("click", () => {
  window.scrollTo({ top: 0, behavior: "smooth" });
});

const paras = document.querySelectorAll(".post-article p");
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add("visible"); });
});
paras.forEach(p => { p.classList.add("fade"); obs.observe(p); });
</script>

<style>
#progress {
  position: fixed;
  top: 0;
  left: 0;
  height: 3px;
  background: var(--color-accent);
  width: 0%;
  z-index: 90;
}
.back-link {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-decoration: none;
  color: var(--color-muted);
  margin: 2rem 0 2.5rem;
  transition: color 140ms ease;
}
.back-link:hover { color: var(--color-accent); }
.post-header {
  text-align: center;
  padding-bottom: 2rem;
  margin-bottom: 2rem;
}
.post-title {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 900;
  line-height: 1.1;
  margin: 0 0 1rem;
  color: var(--color-ink);
}
.post-byline {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--color-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}
.byline-sep { opacity: 0.4; }
.post-rule {
  width: 60px;
  height: 2px;
  background: var(--color-accent);
  margin: 1.5rem auto 0;
}
.post-hero-figure {
  margin: 0 0 2.5rem;
}
.post-hero-figure img {
  width: 100%;
  height: auto;
  display: block;
}
.post-article {
  font-size: 1.08rem;
  line-height: 1.9;
  color: var(--color-ink);
}
.post-article p { margin-bottom: 1.5em; }
.post-article h2,
.post-article h3 {
  font-family: var(--font-serif);
  color: var(--color-ink);
  margin: 2.2em 0 0.6em;
}
.post-article img {
  width: 100%;
  height: auto;
  border: 1px solid var(--color-border);
  margin: 2rem 0;
  display: block;
}
.related-posts {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border);
}
.related-list {
  display: grid;
  gap: 1rem;
}
.related-item {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 1rem;
  text-decoration: none;
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--color-border);
  transition: color 140ms ease;
}
.related-item:hover .related-title { color: var(--color-accent); }
.related-title {
  font-family: var(--font-serif);
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-ink);
  transition: color 140ms ease;
}
.related-meta {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-muted);
  white-space: nowrap;
}
.fade {
  opacity: 0;
  transform: translateY(6px);
  transition: 0.5s ease;
}
.fade.visible {
  opacity: 1;
  transform: none;
}
</style>
