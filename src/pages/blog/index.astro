---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import { slugify, withBase } from '../../utils/slugify';
import readingTime from 'reading-time';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---
<PageLayout title="Blog · Almost a Footnote" description="Writing on law, arbitration, corporate practice, and legal reasoning.">
  <section class="content-shell py-10">
    <header class="border-b border-[color:var(--color-border)] pb-6 mb-2">
      <p class="eyebrow">Writing</p>
      <h1 class="m-0 text-2xl">All Posts</h1>
    </header>
    <div>
      {posts.map((post) => (
        <article class="post-list-item">
          <div class="post-list-meta">
            {new Date(post.data.pubDate).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}
            &nbsp;·&nbsp;
            {readingTime(post.body ?? '').text}
          </div>
          <h3>
            <a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a>
          </h3>
          {post.data.description && (
            <p class="post-list-description">{post.data.description}</p>
          )}
          {post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-2">
              {post.data.tags.map((tag) => (
                <a href={withBase(`/tags/${slugify(tag)}/`)} class="post-tag">{tag}</a>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>
  </section>
</PageLayout>
