---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import PostList from '../components/PostList.astro';
import { getSite } from '../utils/consts';
import { getCollection } from 'astro:content';
import readingTime from 'reading-time';
const site = await getSite();
const posts = await getCollection('blog');
const sorted = posts.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime();
});
const featured = sorted[0];
---
<PageLayout title={site.title}>
  <Hero
    title={site.hero?.title}
    description={site.hero?.subtitle}
    actions={[
      { label: "Start Reading", href: "/blog", variant: "primary" },
      { label: "About Me", href: "/about", variant: "secondary" }
    ]}
  />
  {featured && (
    <section class="content-shell pt-10 pb-10 border-b border-[color:var(--color-border)]">
      <p class="eyebrow mb-4">Featured Writing</p>
      <a href={`/blog/${featured.id}/`} class="featured-post group block">
        <h2 class="m-0 mb-2">{featured.data.title}</h2>
        <p class="text-xs font-mono uppercase tracking-widest text-muted mb-3">
          {readingTime(featured.body ?? '').text}
        </p>
        <p class="text-muted text-base leading-relaxed m-0">
          {featured.data.description}
        </p>
      </a>
    </section>
  )}
  <About author={site.author} />
  <section class="content-shell mt-10 mb-16">
    <p class="eyebrow mb-6">All Writing</p>
    <PostList />
  </section>
</PageLayout>
