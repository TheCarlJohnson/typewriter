---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import { getSite } from '../../utils/consts';
import { slugify, withBase } from '../../utils/slugify';
const site = await getSite();
const posts = await getCollection('blog');
const tags = new Map<string, string>();
posts.forEach((post) => {
	(post.data.tags ?? []).forEach((tag) => {
		tags.set(slugify(tag), tag);
	});
});
const tagList = Array.from(tags.entries()).sort((a, b) => a[1].localeCompare(b[1]));
---
<PageLayout title={`Tags · ${site.title}`} description="Browse all tags">
	<section class="content-shell py-12 space-y-8">
		<header class="space-y-2 border-b border-[color:var(--color-border)] pb-6">
			<p class="eyebrow">Tags</p>
			<h1 class="text-3xl font-semibold">All Tags</h1>
			<p class="text-muted text-sm">{tagList.length} {tagList.length === 1 ? 'tag' : 'tags'}</p>
		</header>
		<div class="flex flex-wrap gap-3">
			{tagList.map(([slug, label]) => (
				<a href={withBase(`/tags/${slug}/`)} class="post-tag">
					{label}
				</a>
			))}
		</div>
	</section>
</PageLayout>

<style>
.post-tag {
	font-size: 0.65rem;
	font-family: var(--font-mono, monospace);
	text-transform: uppercase;
	letter-spacing: 0.1em;
	color: var(--color-muted);
	border: 1px solid var(--color-border);
	padding: 0.15rem 0.5rem;
	text-decoration: none;
	transition: color 140ms ease, border-color 140ms ease;
}
.post-tag:hover {
	color: var(--color-ink);
	border-color: var(--color-ink);
}
</style>
