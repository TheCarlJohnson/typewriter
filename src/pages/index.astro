---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import PostList from '../components/PostList.astro';
import { getSite } from '../utils/consts';
import { getCollection } from 'astro:content';
import readingTime from 'reading-time';

const site = await getSite();
const posts = await getCollection('blog');

const featured = posts[0];
---

<PageLayout title={site.title}>

<Hero
  title={site.hero?.title}
  description={site.hero?.subtitle}
  actions={[
    { label: "Start Reading", href: "/blog", variant: "primary" },
    { label: "About Me", href: "/about", variant: "secondary" }
  ]}
/>

{/* Featured Post */}

{featured && (
<section class="content-shell mt-16 space-y-4 border-b pb-12">

  <p class="text-xs uppercase tracking-widest text-muted">
    Featured Writing
  </p>

  <a
    href={`/blog/${featured.id}/`}
    class="block space-y-3 rounded-lg border p-6 hover:bg-[color:var(--color-surface)] transition"
  >

    <h2 class="text-2xl font-semibold">
      {featured.data.title}
    </h2>

    <p class="text-xs text-muted">
      {readingTime(featured.body).text}
    </p>

    <p class="text-muted">
      {featured.data.description}
    </p>

  </a>

</section>
)}

<About author={site.author} />

<section class="content-shell mt-16">
  <PostList />
</section>

</PageLayout>
