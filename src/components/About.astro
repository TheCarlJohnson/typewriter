---
interface Props {
  author?: any;
}
const { author } = Astro.props as Props;
---
{author ? (
  <section class="content-shell py-12 border-t border-[color:var(--color-border)]">
    <div class="max-w-xl space-y-3">
      <p class="eyebrow">About</p>
      <h2 class="text-2xl font-semibold m-0">{author.name}</h2>
      {author.bio && (
        <p class="text-muted text-base leading-relaxed">{author.bio}</p>
      )}
      <a href="/about" class="text-sm underline underline-offset-4">
        Read more
      </a>
    </div>
  </section>
) : null}
