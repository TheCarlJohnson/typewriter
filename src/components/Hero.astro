---
interface Action {
  label: string;
  href: string;
  variant?: 'primary' | 'secondary';
}
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  actions?: Action[];
}
import { withBase } from '../utils/slugify';
const { eyebrow, title, description, actions = [] } = Astro.props;
---
<section class="content-shell">
  <div class="hero">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h1>{title}</h1>
    {description && <p>{description}</p>}
    {actions.length > 0 && (
      <div class="flex flex-wrap gap-3 mt-6">
        {actions.map((action) => (
          <a class={`button ${action.variant ?? 'primary'}`} href={withBase(action.href)}>
            {action.label}
          </a>
        ))}
      </div>
    )}
  </div>
</section>
