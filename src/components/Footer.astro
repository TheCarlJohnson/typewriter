---
import { getSite } from '../utils/consts';
import Clock from './Clock.astro';
import AmbientToggle from './AmbientToggle.astro';
const site = await getSite();
const today = new Date();
---
<footer class="border-t border-[color:var(--color-border)] mt-16 py-8">
  <div class="content-shell">

    <div class="flex flex-wrap items-start justify-between gap-8 border-b border-[color:var(--color-border)] pb-8">

      <div class="space-y-3">
        <p class="eyebrow">Navigation</p>
        <div class="flex flex-col gap-1.5 text-sm text-muted">
          <a class="hover:text-[color:var(--color-ink)] transition-colors" href="/">Home</a>
          <a class="hover:text-[color:var(--color-ink)] transition-colors" href="/blog">Blog</a>
          <a class="hover:text-[color:var(--color-ink)] transition-colors" href="/about">About</a>
          <a class="hover:text-[color:var(--color-ink)] transition-colors" href="/rss.xml">RSS</a>
        </div>
      </div>

      <div class="space-y-3 text-right">
        <p class="eyebrow">Where I am</p>
        <div class="flex flex-wrap items-center gap-3 justify-end">
          <Clock label="India" timeZone="Asia/Kolkata" />
        </div>
      </div>

    </div>

    <div class="flex flex-wrap items-center justify-between gap-4 pt-6 text-xs text-muted">
      <p class="m-0">© {today.getFullYear()} Tanmay · Almost a Footnote</p>
      <AmbientToggle />
    </div>

  </div>
</footer>
