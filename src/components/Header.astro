---
import HeaderLink from './HeaderLink.astro';
import SearchModal from './SearchModal.astro';
import ThemeToggle from './ThemeToggle.astro';
const subpath = import.meta.env.BASE_URL;
---
<header class="sticky top-0 z-40 backdrop-blur bg-[color:var(--color-surface)] border-b border-[color:var(--color-border)]">
	<div class="content-shell py-3 md:py-4">
		<div class="flex items-center justify-between gap-4">
			<h1 class="text-sm font-semibold uppercase m-0 tracking-widest whitespace-nowrap">
				<a href={subpath} class="no-underline hover:opacity-70 transition-opacity">Almost a Footnote</a>
			</h1>
			<nav class="hidden md:flex items-center gap-6 text-[0.68rem] tracking-[0.28em] uppercase text-muted">
				<HeaderLink href="/blog">Blog</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
			</nav>
			<div class="flex items-center gap-2 shrink-0">
				<SearchModal />
				<ThemeToggle />
			</div>
		</div>
	</div>
</header>

<script is:inline>
const applyNav = (state) => {
	document.documentElement.dataset.nav = state === 'open' ? 'open' : 'closed';
};
applyNav('closed');
</script>
