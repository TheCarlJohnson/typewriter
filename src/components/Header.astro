---
import HeaderLink from './HeaderLink.astro';
import SearchModal from './SearchModal.astro';
import ThemeToggle from './ThemeToggle.astro';
const subpath = import.meta.env.BASE_URL;
---
<header class="bg-[color:var(--color-surface)] border-b border-[color:var(--color-border)]">
  <div style="height:4px; background:var(--color-accent); width:100%;"></div>
  <div class="content-shell py-5 text-center">
    <a href={subpath} class="no-underline hover:opacity-70 transition-opacity" style="font-family:var(--font-serif); font-size:1.05rem; font-weight:700; letter-spacing:0.25em; text-transform:uppercase;">
      Almost a Footnote
    </a>
  </div>
  <div class="border-t border-b border-[color:var(--color-border)]">
    <div class="content-shell py-2 flex items-center justify-between">
      <nav class="flex items-center gap-6 text-[0.68rem] tracking-[0.28em] uppercase text-muted">
        <HeaderLink href="/blog">Blog</HeaderLink>
        <HeaderLink href="/about">About</HeaderLink>
      </nav>
      <div class="flex items-center gap-2">
        <SearchModal />
        <ThemeToggle />
      </div>
    </div>
  </div>
</header>

<script is:inline>
document.documentElement.dataset.nav = 'closed';
</script>
