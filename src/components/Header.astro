---
import HeaderLink from './HeaderLink.astro';
import SearchModal from './SearchModal.astro';
import ThemeToggle from './ThemeToggle.astro';
const subpath = import.meta.env.BASE_URL;
---
<header class="sticky top-0 z-40 backdrop-blur bg-[color:var(--color-surface)] border-b border-[color:var(--color-border)]">
	<div class="content-shell py-3">
		<div class="flex items-center justify-between gap-4">
			<a href={subpath} class="text-xs font-semibold uppercase tracking-widest no-underline hover:opacity-70 transition-opacity whitespace-nowrap">
				Almost a Footnote
			</a>
			<nav class="hidden md:flex items-center gap-6 text-[0.68rem] tracking-[0.28em] uppercase text-muted">
				<HeaderLink href="/blog">Blog</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
			</nav>
			<div class="flex items-center gap-2 shrink-0">
				<SearchModal />
				<ThemeToggle />
			</div>
		</div>
	</div>
</header>

<script is:inline>
document.documentElement.dataset.nav = 'closed';
</script>
